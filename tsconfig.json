{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "modules/*": ["src/modules/*"],
      "navigation": ["src/navigation"],
      "navigation/*": ["src/navigation/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "nativewind-env.d.ts"],
  "exclude": ["node_modules"]
}
